{
  "name": "ouzx.me",
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "husky",
    "commit": "git add -A && cz",
    "commit:stage": "cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "commitizen": "^4.3.1",
    "cz-emoji": "1.3.2-canary.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "turbo": "^2.3.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-emoji"
    }
  },
  "author": "Ouzx",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  }
}