{
  "name": "@ouzx-me/logger",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@ouzx-me/eslint-config": "workspace:*",
    "@ouzx-me/typescript-config": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.0.2"
  },
  "lint-staged": {
    "*": [
      "eslint --fix"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit"
    ]
  }
}
